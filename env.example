TELEGRAM_BOT_TOKEN=8870763106:AAFE-JhQSQq2j-akZ8xwibI3b9dGIpm-L1Q
TELEGRAM_CHANNEL_ID=@cryptoPriceTodayBot
INTERVAL=1m

# فاصله ارسال عکس نمودار (هر مقدار time.ParseDuration مثل 30s, 5m, 1h)
CHART_INTERVAL=5m

# پنجره نمایش روی نمودار:
#   session : از لحظه شروع ربات تا الان
#   مقدار duration مثل 5m, 1h, 24h
CHART_WINDOW=session

# فاصله نمونه‌گیری مستقل برای پر کردن history نمودار. هرچه کوتاه‌تر، نمودار صاف‌تر —
# ولی مصرف CoinGecko بیشتر می‌شود (sweet spot ~15–30s).
SAMPLE_INTERVAL=20s

# سرویس رندر نمودار. پیش‌فرض quickchart.io رایگان (60 req/min). اگر می‌خواهی
# بدون محدودیت باشد، با docker سلف-هاست کن:
#   docker run -d -p 8080:3400 --name quickchart ianw/quickchart
# و QUICKCHART_URL=http://localhost:8080 بگذار.
QUICKCHART_URL=https://quickchart.io